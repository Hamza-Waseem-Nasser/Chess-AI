{
  "$schema": "https://openapi.vercel.sh/vercel.json",

  "framework": "vite",

  "buildCommand": "npx vite build",
  "outputDirectory": "dist",
  "installCommand": "npm install",

  "functions": {
    "api/**/*.js": {
      "maxDuration": 60
    }
  },

  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" }
  ]
}
